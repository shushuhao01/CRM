# =============================================
# 云客 CRM 社区版 - 环境变量配置
# 复制此文件为 .env 并修改对应的值
# =============================================

# 后端服务端口
PORT=3000

# 前端开发服务端口（开发模式使用）
VITE_PORT=5173

# 数据库配置（必填）
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=yunke_crm
DB_USERNAME=root
DB_PASSWORD=your_password_here

# JWT 密钥（请修改为随机字符串）
JWT_SECRET=your-jwt-secret-change-this
JWT_EXPIRES_IN=7d

# 部署模式（社区版固定为 private）
DEPLOY_MODE=private

# 文件上传目录
UPLOAD_DIR=./uploads

# 日志级别
LOG_LEVEL=info

# 前端 API 地址（开发模式）
VITE_API_BASE_URL=http://localhost:3000

# 官网地址（用于升级引导）
VITE_WEBSITE_URL=https://www.yunkes.com
