# ==================== CRM 系统环境配置 ====================
# ⚠️ 部署时请将所有 your_xxx 占位符替换为实际值
# 本文件从 .env.example 生成，详细说明请参考 .env.example
# ==============================================================

# 服务器配置
NODE_ENV=production
PORT=3000
API_PREFIX=/api/v1

# 部署模式: private(私有部署) | saas(SaaS多租户)
DEPLOY_MODE=saas

# ==================== 数据库配置 (MySQL 8.0+) ====================
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password
DB_CHARSET=utf8mb4
DB_TIMEZONE=+08:00

# ==================== JWT 配置 ====================
# ⚠️ 生产环境请生成独立密钥: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 加密配置
BCRYPT_ROUNDS=12

# ==================== CORS 配置 ====================
# ⚠️ 生产环境改为实际域名列表
CORS_ORIGIN=https://crm.yourdomain.com,https://admin.yourdomain.com,https://www.yourdomain.com
CORS_CREDENTIALS=true

# 文件上传配置
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf

# ==================== 日志配置 ====================
LOG_LEVEL=info
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# ==================== 安全配置 ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=3000
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_REQUESTS=50
HELMET_ENABLED=true
COMPRESSION_ENABLED=true

# ==================== 邮件配置（按需） ====================
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ==================== 部署配置 ====================
BAOTA_PANEL=false
STATIC_PATH=../dist
UPLOAD_PATH=./uploads
ENABLE_ADMIN=true

# ==================== 第三方服务（按需） ====================
# 快递100 API
EXPRESS_API_CUSTOMER=
EXPRESS_API_KEY=
EXPRESS_API_URL=https://poll.kuaidi100.com/poll/query.do
EXPRESS_API_TIMEOUT=10000

# 阿里云短信
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
