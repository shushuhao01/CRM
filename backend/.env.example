# ==================== CRM 系统环境配置模板 ====================
# 使用方式:
#   本地开发: 复制为 .env.local 并修改数据库配置
#   生产部署: 复制为 .env 并修改所有 your_xxx 占位符为实际值
# ==============================================================

# 服务器配置
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# 部署模式: private(私有部署) | saas(SaaS多租户)
DEPLOY_MODE=saas

# 服务器URL配置（生产环境改为实际域名）
# API_BASE_URL=https://your-domain.com

# ==================== 系统URL地址配置 ====================
# ⚠️ 多域名部署时必须配置（影响跨系统链接、邮件通知、支付回调等）
# 不配置则使用 backend/src/config/sites.ts 中的默认值
# CRM_URL=https://crm.your-domain.com
# WEBSITE_URL=https://your-domain.com
# API_URL=https://api.your-domain.com
# ADMIN_URL=https://admin.your-domain.com
# RENEW_URL=https://your-domain.com/pricing

# ==================== 数据库配置 (MySQL 8.0+) ====================
# ⚠️ 必须修改：根据实际数据库信息填写
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password
DB_CHARSET=utf8mb4
DB_TIMEZONE=+08:00

# 数据库部署说明：
# 1. 运行 chmod +x db-deploy.sh && ./db-deploy.sh 进行数据库一键部署
# 2. 或手动创建数据库后导入 backend/database-init.sql
# 3. 确保 MySQL 版本为 8.0+ 以获得最佳兼容性

# ==================== JWT 配置 ====================
# ⚠️ 生产环境请生成独立密钥: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ JWT_SECRET 和 JWT_REFRESH_SECRET 必须不同，且都要配置，否则服务重启后用户需重新登录
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 加密配置
BCRYPT_ROUNDS=12

# ==================== CORS 配置 ====================
# 生产环境改为你的实际域名（需包含CRM/官网/Admin所有域名）
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true

# 文件上传配置
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf

# ==================== 日志配置 ====================
LOG_LEVEL=info
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# ==================== 安全配置 ====================
# 限流: 15分钟内每个IP最多3000次请求
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=3000
# 登录限流: 15分钟内最多50次登录尝试
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_REQUESTS=50
HELMET_ENABLED=true
COMPRESSION_ENABLED=true

# ==================== 邮件配置（按需）====================
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ==================== 部署配置 ====================
# 宝塔面板设为 true
BAOTA_PANEL=false
STATIC_PATH=../dist
UPLOAD_PATH=./uploads

# 平台管理后台
ENABLE_ADMIN=true

# ==================== 第三方服务（按需）====================

# 快递100 API
EXPRESS_API_CUSTOMER=
EXPRESS_API_KEY=
EXPRESS_API_URL=https://poll.kuaidi100.com/poll/query.do
EXPRESS_API_TIMEOUT=10000

# 阿里云短信
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# Redis 缓存（可选，不配置则使用内存缓存）
# REDIS_URL=redis://localhost:6379

# ==================== 私有部署中央服务器配置 ====================
# ⚠️ 私有部署时必须确保能访问中央服务器（用于授权验证、心跳、配置同步等）
# 默认指向云客官方服务器，通常无需修改
# 如有自建管理后台，请修改为对应地址
#
# CENTRAL_API_URL=https://api.yunkes.com
# CENTRAL_ADMIN_URL=https://admin.yunkes.com
# CENTRAL_WEBSITE_URL=https://yunkes.com
# CENTRAL_CRM_URL=https://crm.yunkes.com
#
# 回调项目清单（共12类）：
# 1. 授权码激活         POST /api/v1/admin/verify/license
# 2. 授权心跳同步       POST /api/v1/admin/verify/license （每30分钟）
# 3. 手动同步授权       POST /api/v1/admin/verify/license
# 4. 系统配置同步       GET  /api/v1/admin/public/system-config
# 5. 系统公告           GET  /api/v1/admin/announcements
# 6. 版本更新检查       GET  /api/v1/admin/verify/version
# 7. 企微套餐定价       GET  /api/v1/admin/wecom-management/pricing-config
# 8. 会话存档代购       GET  /api/v1/admin/wecom-management/purchase-orders
# 9. AI助手额度         GET  /api/v1/admin/wecom-management/ai/*
# 10.短信额度模板       GET  /api/v1/admin/sms-quota
# 11.获客助手用量       GET  /api/v1/admin/wecom-management/acquisition-usage
# 12.企微服务商回调     回调URL固定指向 https://api.yunkes.com/api/v1/wecom/suite/callback
