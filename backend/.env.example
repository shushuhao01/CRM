# ==================== CRM v1.8 环境配置模板 ====================
# 使用方法:
#   本地开发: 复制为 .env.local 并修改数据库等配置
#   生产部署: 复制为 .env 并替换所有 your_xxx 占位符
#
# 快速部署步骤:
#   1. cp .env.example .env
#   2. 修改数据库配置 (DB_*)
#   3. 生成JWT密钥: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   4. 修改CORS_ORIGIN为实际域名
#   5. 修改站点URL为实际域名
# ==============================================================

# ==================== 基础配置 ====================
NODE_ENV=production
PORT=3000
API_PREFIX=/api/v1

# 部署模式: private(私有部署-单租户) | saas(SaaS-多租户)
DEPLOY_MODE=saas
SAAS_LICENSE_TOKEN=

# ==================== 数据库配置 (MySQL 8.0+) ====================
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password
DB_CHARSET=utf8mb4
DB_TIMEZONE=+08:00
# 连接池大小: 2G内存=10, 4G内存=20, 8G+=30-50
DB_CONNECTION_LIMIT=10

# ==================== JWT 认证 ====================
# ⚠️ 必须替换! 生成命令: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 密码加密轮数: 2G服务器=10, 4G+=12
BCRYPT_ROUNDS=10

# ==================== CORS 跨域 ====================
# ⚠️ 生产环境必须指定域名，开发环境可用 *
CORS_ORIGIN=https://crm.yourdomain.com,https://admin.yourdomain.com
CORS_CREDENTIALS=true

# ==================== 文件上传 ====================
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet
UPLOAD_PATH=./uploads
STATIC_PATH=../dist

# ==================== 日志 ====================
LOG_LEVEL=info
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# ==================== 安全与限流 ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=3000
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_REQUESTS=50
HELMET_ENABLED=true
COMPRESSION_ENABLED=true

# ==================== 站点URL ====================
# ⚠️ 替换为你的实际域名
SERVER_URL=https://api.yourdomain.com
API_BASE_URL=https://api.yourdomain.com
CRM_URL=https://crm.yourdomain.com
ADMIN_URL=https://admin.yourdomain.com
WEBSITE_URL=https://www.yourdomain.com
RENEW_URL=https://www.yourdomain.com/pricing

# ==================== 中央服务器（私有部署同步用） ====================
CENTRAL_API_URL=https://api.yunkes.com
CENTRAL_ADMIN_URL=https://admin.yunkes.com
CENTRAL_WEBSITE_URL=https://yunkes.com
CENTRAL_CRM_URL=https://crm.yunkes.com

# ==================== 私有部署授权 ====================
# 从管理后台获取授权Key
# LICENSE_KEY=your_license_key
# LICENSE_SERVER=https://admin.yunkes.com

# ==================== SaaS 多租户（按需） ====================
# TENANT_ID=
# TENANT_LICENSE_KEY=

# ==================== 部署选项 ====================
BAOTA_PANEL=false
ENABLE_ADMIN=true
ADMIN_CAPTCHA_REQUIRED=true

# ==================== 邮件（可选） ====================
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ==================== 快递100 API（可选） ====================
EXPRESS_API_CUSTOMER=
EXPRESS_API_KEY=
EXPRESS_API_URL=https://poll.kuaidi100.com/poll/query.do
EXPRESS_API_TIMEOUT=10000

# ==================== 阿里云短信（可选） ====================
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# ==================== 小程序（可选） ====================
MP_APP_ID=
MP_APP_SECRET=
MP_FORM_SECRET=your_mp_form_secret
MP_LINK_EXPIRE_DAYS=7
MP_CALLBACK_TOKEN=

# ==================== 企业微信（可选） ====================
# SIDEBAR_ALLOWED_DOMAINS=yourdomain.com
