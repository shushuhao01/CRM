.expired-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 48rpx;
  text-align: center;
  background: linear-gradient(180deg, #fff8e1 0%, #f5f7fa 40%);
}

.expired-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx 40rpx;
  width: 100%;
  max-width: 560rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 32rpx;
}

.expired-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.expired-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1d2129;
  margin-bottom: 12rpx;
}

.expired-desc {
  font-size: 28rpx;
  color: #86909c;
  line-height: 1.6;
}

.expired-tips {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  width: 100%;
  max-width: 560rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.tip-item {
  font-size: 24rpx;
  color: #4e5969;
  line-height: 2.2;
  text-align: left;
}
