<view class="form-page" wx:if="{{!loading && !error}}">
  <!-- 顶部邀请卡片 -->
  <view class="invite-card">
    <view class="invite-text">邀请您填写个人资料</view>
    <view class="invite-badge">
      <text class="badge-text">信息安全加密传输</text>
    </view>
    <view class="invite-code" wx:if="{{tenantCode || tenantId}}">{{tenantCode || tenantId}}</view>
  </view>

  <!-- 智能识别填充区域 -->
  <view class="smart-paste-section">
    <view class="smart-paste-header">
      <text class="smart-paste-title">智能识别填充区域</text>
      <text class="smart-paste-tip">粘贴文本自动识别姓名、手机号</text>
    </view>
    <view class="smart-paste-body">
      <textarea class="smart-paste-input" placeholder="粘贴包含姓名、手机号的文本，如：张三 13800138000 广东省广州市海珠区阅江西路222号" value="{{smartPasteText}}" bindinput="onSmartPasteInput" maxlength="500" auto-height="true" />
      <view class="smart-paste-actions">
        <view class="smart-paste-btn paste" bindtap="onSmartPasteFromClipboard">粘贴信息</view>
        <view class="smart-paste-btn recognize" bindtap="onSmartPasteRecognize">识别填充</view>
        <view class="smart-paste-btn clear" bindtap="onSmartPasteClear" wx:if="{{smartPasteText}}">清空</view>
      </view>
    </view>
  </view>

  <!-- 表单主体 -->
  <view class="form-body">
    <!-- 基本信息（必填 + 非折叠启用字段） -->
    <view class="form-section">
      <view class="section-title">
        <view class="section-title-bar"></view>
        <text>基本信息</text>
      </view>

      <block wx:for="{{visibleFields}}" wx:key="key">
        <!-- 姓名 -->
        <view class="form-item" wx:if="{{item.key === 'name'}}">
          <view class="form-label">
            <text>{{item.label}}</text>
            <text class="required" wx:if="{{item.mpRequired}}">*</text>
          </view>
          <input class="form-input" placeholder="请输入姓名" value="{{formData.name}}" bindinput="onInputChange" data-field="name" />
        </view>

        <!-- 手机号（含一键获取按钮） -->
        <view class="form-item" wx:elif="{{item.key === 'phone'}}">
          <view class="form-label">
            <text>{{item.label}}</text>
            <text class="required" wx:if="{{item.mpRequired}}">*</text>
          </view>
          <view class="phone-inline">
            <input class="form-input phone-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{formData.phone}}" bindinput="onInputChange" data-field="phone" />
            <button class="btn-get-phone" wx:if="{{phoneAuthEnabled}}" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">{{formData.phone ? '重新获取' : '获取手机号'}}</button>
          </view>
        </view>

        <!-- 性别 -->
        <view class="form-item" wx:elif="{{item.key === 'gender'}}">
          <view class="form-label">
            <text>{{item.label}}</text>
            <text class="required" wx:if="{{item.mpRequired}}">*</text>
          </view>
          <view class="gender-group">
            <view class="gender-btn {{formData.gender === '男' ? 'active' : ''}}" bindtap="onGenderSelect" data-value="男">男</view>
            <view class="gender-btn {{formData.gender === '女' ? 'active' : ''}}" bindtap="onGenderSelect" data-value="女">女</view>
          </view>
        </view>

        <!-- 年龄 -->
        <view class="form-item" wx:elif="{{item.key === 'age'}}">
          <view class="form-label">
            <text>{{item.label}}</text>
            <text class="required" wx:if="{{item.mpRequired}}">*</text>
          </view>
          <input class="form-input" type="number" maxlength="3" placeholder="请输入年龄" value="{{formData.age}}" bindinput="onInputChange" data-field="age" />
        </view>

        <!-- 生日 -->
        <view class="form-item" wx:elif="{{item.key === 'birthday'}}">
          <view class="form-label">
            <text>{{item.label}}</text>
            <text class="required" wx:if="{{item.mpRequired}}">*</text>
          </view>
          <picker mode="date" bindchange="onBirthdayChange">
            <view class="form-input picker-value">
              <text wx:if="{{formData.birthday}}">{{formData.birthday}}</text>
              <text wx:else class="placeholder">请选择生日</text>
            </view>
          </picker>
        </view>

        <!-- 收货地址（省市区下拉选择 + 街道下拉 + 详细地址） -->
        <view class="form-item" wx:elif="{{item.key === 'address' || item.key === 'province'}}">
          <view class="form-label">
            <text>收货地址</text>
            <text class="required" wx:if="{{item.mpRequired}}">*</text>
          </view>
          <!-- 省/市/区 三级联动 -->
          <picker mode="region" bindchange="onRegionChange" value="{{[formData.province, formData.city, formData.district]}}">
            <view class="form-input picker-value">
              <text wx:if="{{formData.province}}">{{formData.province}} {{formData.city}} {{formData.district}}</text>
              <text wx:else class="placeholder">请选择省/市/区</text>
            </view>
          </picker>
          <!-- 街道下拉选择（含手动输入选项） -->
          <picker wx:if="{{streetLabels.length > 0 && !streetManualInput}}" mode="selector" range="{{streetLabels}}" bindchange="onStreetChange" style="margin-top:12rpx">
            <view class="form-input picker-value">
              <text wx:if="{{formData.street}}">{{formData.street}}</text>
              <text wx:else class="placeholder">请选择街道/乡镇（点击选择）</text>
            </view>
          </picker>
          <view wx:if="{{streetLabels.length > 0 && !streetManualInput}}" style="margin-top:8rpx;text-align:right">
            <text class="street-manual-btn" bindtap="onStreetManualToggle">找不到？手动输入</text>
          </view>
          <view wx:if="{{streetLabels.length === 0 || streetManualInput}}">
            <input class="form-input" style="margin-top:12rpx" placeholder="街道/乡镇（选填，可手动输入）" value="{{formData.street}}" bindinput="onInputChange" data-field="street" />
            <view wx:if="{{streetManualInput}}" style="margin-top:8rpx;text-align:right">
              <text class="street-manual-btn" bindtap="onStreetManualToggle">返回列表选择</text>
            </view>
          </view>
          <!-- 详细地址 -->
          <input class="form-input" style="margin-top:12rpx" placeholder="详细地址（门牌号、楼层等）" value="{{formData.detailAddress}}" bindinput="onInputChange" data-field="detailAddress" />
        </view>

        <!-- 跳过地址子字段 -->
        <block wx:elif="{{item.key === 'city' || item.key === 'district' || item.key === 'street' || item.key === 'detailAddress'}}"></block>

        <!-- 邮箱 -->
        <view class="form-item" wx:elif="{{item.key === 'email'}}">
          <view class="form-label">
            <text>{{item.label}}</text>
            <text class="required" wx:if="{{item.mpRequired}}">*</text>
          </view>
          <input class="form-input" type="text" placeholder="请输入邮箱" value="{{formData.email}}" bindinput="onInputChange" data-field="email" />
        </view>

        <!-- 微信号 -->
        <view class="form-item" wx:elif="{{item.key === 'wechat'}}">
          <view class="form-label">
            <text>{{item.label}}</text>
            <text class="required" wx:if="{{item.mpRequired}}">*</text>
          </view>
          <input class="form-input" type="text" placeholder="请输入微信号" value="{{formData.wechat}}" bindinput="onInputChange" data-field="wechat" />
        </view>

        <!-- 身高 -->
        <view class="form-item" wx:elif="{{item.key === 'height'}}">
          <view class="form-label">
            <text>{{item.label}}</text>
            <text class="required" wx:if="{{item.mpRequired}}">*</text>
          </view>
          <input class="form-input" type="digit" placeholder="请输入身高(cm)" value="{{formData.height}}" bindinput="onInputChange" data-field="height" />
        </view>

        <!-- 体重 -->
        <view class="form-item" wx:elif="{{item.key === 'weight'}}">
          <view class="form-label">
            <text>{{item.label}}</text>
            <text class="required" wx:if="{{item.mpRequired}}">*</text>
          </view>
          <input class="form-input" type="digit" placeholder="请输入体重(kg)" value="{{formData.weight}}" bindinput="onInputChange" data-field="weight" />
        </view>

        <!-- 通用文本字段 -->
        <view class="form-item" wx:else>
          <view class="form-label">
            <text>{{item.label}}</text>
            <text class="required" wx:if="{{item.mpRequired}}">*</text>
          </view>
          <input class="form-input" placeholder="请输入{{item.label}}" value="{{formData[item.key]}}" bindinput="onInputChange" data-field="{{item.key}}" />
        </view>
      </block>
    </view>

    <!-- 更多信息（折叠的非必填字段） -->
    <view class="form-section" wx:if="{{collapsedFields.length > 0}}">
      <view class="section-title expand-header" bindtap="toggleCollapsed">
        <view style="display:flex;align-items:center;gap:8rpx">
          <view class="section-title-bar" style="background:#e6a23c"></view>
          <text>更多信息（选填）</text>
        </view>
        <view class="expand-hint-wrap">
          <text class="expand-hint-text">{{showCollapsed ? '收起' : '展开更多'}}</text>
          <text class="expand-icon {{showCollapsed ? 'expanded' : ''}}">▶</text>
        </view>
      </view>

      <block wx:if="{{showCollapsed}}">
        <block wx:for="{{collapsedFields}}" wx:key="key">
          <!-- 性别（折叠区） -->
          <view class="form-item" wx:if="{{item.key === 'gender'}}">
            <view class="form-label"><text>{{item.label}}</text></view>
            <view class="gender-group">
              <view class="gender-btn {{formData.gender === '男' ? 'active' : ''}}" bindtap="onGenderSelect" data-value="男">男</view>
              <view class="gender-btn {{formData.gender === '女' ? 'active' : ''}}" bindtap="onGenderSelect" data-value="女">女</view>
            </view>
          </view>
          <!-- 生日（折叠区） -->
          <view class="form-item" wx:elif="{{item.key === 'birthday'}}">
            <view class="form-label"><text>{{item.label}}</text></view>
            <picker mode="date" bindchange="onBirthdayChange">
              <view class="form-input picker-value">
                <text wx:if="{{formData.birthday}}">{{formData.birthday}}</text>
                <text wx:else class="placeholder">请选择生日</text>
              </view>
            </picker>
          </view>
          <!-- 通用字段（折叠区） -->
          <view class="form-item" wx:else>
            <view class="form-label"><text>{{item.label}}</text></view>
            <input class="form-input" placeholder="请输入{{item.label}}" value="{{formData[item.key]}}" bindinput="onInputChange" data-field="{{item.key}}" />
          </view>
        </block>
      </block>
    </view>

    <!-- 备注（始终显示） -->
    <view class="form-section">
      <view class="section-title">
        <view class="section-title-bar" style="background:#909399"></view>
        <text>备注</text>
      </view>
      <view class="form-item">
        <textarea class="form-textarea" placeholder="如有其他需要说明的，请在此填写" value="{{formData.remark}}" bindinput="onInputChange" data-field="remark" maxlength="500" auto-height="true" />
      </view>
    </view>

    <!-- 补充信息（自定义字段，有配置才显示） -->
    <view class="form-section" wx:if="{{customFields.length > 0}}">
      <view class="section-title">
        <view class="section-title-bar" style="background:#67c23a"></view>
        <text>补充信息</text>
      </view>
      <block wx:for="{{customFields}}" wx:key="fieldKey">
        <view class="form-item">
          <view class="form-label">
            <text>{{item.fieldName}}</text>
            <text class="required" wx:if="{{item.mpRequired}}">*</text>
          </view>

          <!-- 文本/数字 -->
          <input wx:if="{{item.fieldType === 'text' || item.fieldType === 'number'}}" class="form-input" type="{{item.fieldType === 'number' ? 'digit' : 'text'}}" placeholder="{{item.placeholder || '请输入' + item.fieldName}}" value="{{customFormData[item.fieldKey]}}" bindinput="onCustomInputChange" data-field="{{item.fieldKey}}" />

          <!-- 选择类 -->
          <picker wx:elif="{{item.fieldType === 'select' || item.fieldType === 'radio'}}" mode="selector" range="{{item.optionLabels}}" bindchange="onCustomPickerChange" data-field="{{item.fieldKey}}" data-options="{{item.options}}">
            <view class="form-input picker-value">
              <text wx:if="{{customFormData[item.fieldKey]}}">{{customFormData[item.fieldKey]}}</text>
              <text wx:else class="placeholder">请选择{{item.fieldName}}</text>
            </view>
          </picker>

          <!-- 日期 -->
          <picker wx:elif="{{item.fieldType === 'date' || item.fieldType === 'datetime'}}" mode="date" bindchange="onCustomDateChange" data-field="{{item.fieldKey}}">
            <view class="form-input picker-value">
              <text wx:if="{{customFormData[item.fieldKey]}}">{{customFormData[item.fieldKey]}}</text>
              <text wx:else class="placeholder">请选择{{item.fieldName}}</text>
            </view>
          </picker>
        </view>
      </block>
    </view>
  </view>

  <!-- 协议勾选 -->
  <view class="agreement-section">
    <view class="agreement-row" bindtap="toggleAgreement">
      <view class="agreement-checkbox {{agreedPrivacy ? 'checked' : ''}}">
        <text wx:if="{{agreedPrivacy}}">✓</text>
      </view>
      <view class="agreement-text">
        <text>我已阅读并同意</text>
        <text class="agreement-link" catchtap="showUserAgreement">《用户协议》</text>
        <text>和</text>
        <text class="agreement-link" catchtap="showPrivacyPolicy">《隐私政策》</text>
      </view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <button class="btn-primary {{!agreedPrivacy ? 'btn-disabled' : ''}}" bindtap="onSubmit" disabled="{{submitting}}">
      {{submitting ? '提交中...' : '提交资料'}}
    </button>
    <view class="submit-tip">您的信息仅用于服务沟通，不会泄露给第三方</view>
  </view>
</view>

<!-- 协议弹窗 -->
<view class="agreement-modal" wx:if="{{showAgreementModal}}" catchtouchmove="true">
