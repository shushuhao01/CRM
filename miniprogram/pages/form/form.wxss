.form-page {
  min-height: 100vh;
  padding-bottom: 40rpx;
  background: #f5f7fa;
}

/* 顶部邀请卡片 */
.invite-card {
  background: linear-gradient(135deg, #409eff 0%, #1677ff 50%, #0958d9 100%);
  padding: 48rpx 32rpx 40rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.invite-text {
  font-size: 52rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  text-align: center;
}

.invite-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  margin-top: 16rpx;
}

.badge-icon { font-size: 20rpx; opacity: 0.7; }
.badge-text { font-size: 22rpx; opacity: 0.85; }

.invite-code {
  position: absolute;
  right: 16rpx;
  bottom: 12rpx;
  font-size: 22rpx;
  opacity: 0.55;
  font-family: monospace;
}

/* 手机号行内获取 */
.phone-inline {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.phone-inline .phone-input {
  flex: 1;
}

.btn-get-phone {
  flex-shrink: 0;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 16rpx;
  background: linear-gradient(135deg, #52c41a, #389e0d);
  color: #fff;
  font-size: 22rpx;
  font-weight: 500;
  border: none;
  border-radius: 12rpx;
  white-space: nowrap;
  max-width: 160rpx;
}

/* 智能识别填充区域 */
.smart-paste-section {
  margin: 20rpx 24rpx 0;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.smart-paste-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #f0f9ff, #e8f4fd);
  border-bottom: 1rpx solid #e8f0fe;
}

.smart-paste-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1677ff;
}

.smart-paste-tip {
  font-size: 20rpx;
  color: #86909c;
}

.smart-paste-body {
  padding: 20rpx 24rpx;
}

.smart-paste-input {
  width: 100%;
  min-height: 120rpx;
  max-height: 200rpx;
  padding: 16rpx 20rpx;
  border: 2rpx dashed #c9cdd4;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #1d2129;
  background: #fafbfc;
  box-sizing: border-box;
  line-height: 1.6;
}

.smart-paste-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  justify-content: flex-end;
}

.smart-paste-btn {
  padding: 0 24rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
  min-height: 0;
  height: 52rpx;
  line-height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.smart-paste-btn.paste {
  background: #e8f5e9;
  color: #43a047;
  border: 1rpx solid #c8e6c9;
}

.smart-paste-btn.recognize {
  background: #e3f2fd;
  color: #1976d2;
  border: 1rpx solid #bbdefb;
}

.smart-paste-btn.clear {
  background: #f5f5f5;
  color: #9e9e9e;
  border: 1rpx solid #e0e0e0;
}

/* 表单主体 */
.form-body {
  padding: 24rpx 24rpx 0;
}

.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #1d2129;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title-bar {
  width: 6rpx;
  height: 28rpx;
  border-radius: 3rpx;
  background: #409eff;
  flex-shrink: 0;
}

.expand-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.expand-hint-wrap {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.expand-hint-text {
  font-size: 24rpx;
  color: #a8abb2;
  font-weight: 400;
}

.expand-icon {
  font-size: 40rpx;
  color: #e6a23c;
  transition: transform 0.3s;
  font-weight: bold;
}

.expand-icon.expanded {
  transform: rotate(90deg);
}

/* 表单项 */
.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 26rpx;
  color: #4e5969;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.required {
  color: #f5222d;
  margin-left: 4rpx;
}

.form-input {
  width: 100%;
  height: 84rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e5e6eb;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: #1d2129;
  box-sizing: border-box;
  transition: border-color 0.2s, box-shadow 0.2s;
  background: #fafbfc;
}

.form-input:focus {
  border-color: #409eff;
  box-shadow: 0 0 0 4rpx rgba(64, 158, 255, 0.1);
  background: #fff;
}

.placeholder {
  color: #c0c4cc;
}

/* 性别选择 */
.gender-group {
  display: flex;
  gap: 16rpx;
}

.gender-btn {
  flex: 1;
  height: 84rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border: 2rpx solid #e5e6eb;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: #4e5969;
  transition: all 0.2s;
  background: #fafbfc;
  line-height: 1;
  white-space: nowrap;
}

.gender-btn.active {
  border-color: #409eff;
  background: linear-gradient(135deg, #f0f5ff, #e8f0ff);
  color: #1677ff;
  font-weight: 600;
  box-shadow: 0 0 0 4rpx rgba(64, 158, 255, 0.08);
}

/* 地址选择 */
.address-picker {
  height: 84rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e5e6eb;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #1d2129;
  margin-bottom: 12rpx;
  background: #fafbfc;
}

.picker-value {
  display: flex;
  align-items: center;
  min-height: 84rpx;
  font-size: 30rpx;
}

/* 街道手动输入切换按钮 */
.street-manual-btn {
  font-size: 22rpx;
  color: #409eff;
  padding: 4rpx 0;
}

/* 备注输入框 */
.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid #e5e6eb;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: #1d2129;
  box-sizing: border-box;
  background: #fafbfc;
  line-height: 1.6;
}

.form-textarea:focus {
  border-color: #409eff;
  background: #fff;
}

/* 协议勾选区域 */
.agreement-section {
  padding: 16rpx 32rpx 0;
}

.agreement-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.agreement-checkbox {
  width: 36rpx;
  height: 36rpx;
  min-width: 36rpx;
  border: 2rpx solid #c0c4cc;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #fff;
  transition: all 0.2s;
}

.agreement-checkbox.checked {
  background: #409eff;
  border-color: #409eff;
}

.agreement-text {
  font-size: 24rpx;
  color: #86909c;
  line-height: 1.6;
}

.agreement-link {
  color: #409eff;
  font-weight: 500;
}

/* 协议弹窗 */
.agreement-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.agreement-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.agreement-modal-content {
  position: relative;
  width: 100%;
  max-height: 85vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.agreement-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.agreement-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1d2129;
}

.agreement-modal-close {
  font-size: 36rpx;
  color: #86909c;
  padding: 8rpx;
  line-height: 1;
}

.agreement-modal-body {
  flex: 1;
  padding: 24rpx 32rpx;
  max-height: 65vh;
  overflow-y: auto;
  overflow-x: hidden;
  box-sizing: border-box;
  word-break: break-all;
  overflow-wrap: break-word;
}

.agreement-modal-footer {
  padding: 20rpx 32rpx 40rpx;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.agreement-modal-btn {
  width: 100%;
  height: 84rpx;
  background: linear-gradient(135deg, #409eff, #1677ff);
  color: #fff;
  border: none;
  border-radius: 14rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 84rpx;
}

/* 协议正文样式 */
.agr-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1d2129;
  text-align: center;
  margin-bottom: 8rpx;
}

.agr-update {
  font-size: 22rpx;
  color: #c0c4cc;
  text-align: center;
  margin-bottom: 28rpx;
}

.agr-h2 {
  font-size: 28rpx;
  font-weight: 700;
  color: #1d2129;
  margin: 24rpx 0 12rpx;
}

.agr-p {
  font-size: 26rpx;
  color: #4e5969;
  line-height: 1.8;
  margin-bottom: 8rpx;
  text-align: justify;
  word-break: break-all;
  overflow-wrap: break-word;
}

/* 提交按钮禁用态 */
.btn-disabled {
  opacity: 0.5;
}

/* 提交区域 */
.submit-section {
  padding: 24rpx 24rpx 32rpx;
}

.submit-tip {
  text-align: center;
  font-size: 22rpx;
  color: #c0c4cc;
  margin-top: 16rpx;
}

/* 加载状态 */
.loading-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: linear-gradient(180deg, #f0f5ff 0%, #f5f7fa 100%);
}

.loading-anim {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #e5e6eb;
  border-top-color: #409eff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #86909c;
}

/* 错误状态 */
.error-page {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 48rpx;
  background: linear-gradient(180deg, #fff5f5 0%, #f5f7fa 100%);
}

.error-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  width: 100%;
  max-width: 560rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.error-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1d2129;
  margin-bottom: 16rpx;
}

.error-text {
  font-size: 26rpx;
  color: #86909c;
  text-align: center;
  line-height: 1.8;
  white-space: pre-wrap;
}
