# ==================== 云客 CRM Docker 部署配置 ====================
# 复制本文件为 .env 并修改以下配置
# 使用方式: cp .env.example .env && nano .env

# ==================== 端口配置 ====================
# Web 访问端口（浏览器访问地址: http://服务器IP:端口）
WEB_PORT=80

# MySQL 外部端口（仅调试用，生产环境可设为 127.0.0.1:3306 或注释掉）
DB_EXTERNAL_PORT=127.0.0.1:3306

# ==================== 数据库配置 ====================
# MySQL root 密码（⚠️ 必须修改）
MYSQL_ROOT_PASSWORD=请设置一个强密码

# 应用数据库名
DB_DATABASE=crm

# 应用数据库用户名
DB_USERNAME=crm

# 应用数据库密码（⚠️ 必须修改）
DB_PASSWORD=请设置一个强密码

# ==================== JWT 配置（⚠️ 必须修改） ====================
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=请生成一个随机密钥
JWT_REFRESH_SECRET=请生成另一个随机密钥

# Token 过期时间
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ==================== CORS 配置 ====================
# 允许跨域的域名（多个用逗号分隔，或设为 * 允许全部）
CORS_ORIGIN=*

# ==================== 日志配置 ====================
LOG_LEVEL=info
