# ==========================================
# CRM 系统 Nginx 配置（宝塔面板直接使用版）
# ==========================================
# 使用方式:
#   宝塔面板 → 网站 → 添加站点 → 设置 → 配置文件
#   将此内容粘贴替换即可，只需修改 server_name 为你的域名或IP
# ==========================================

server {
    listen 80;
    # ★ 修改为你的域名或IP地址
    server_name your-domain.com;

    # 前端文件根目录
    root /www/wwwroot/CRM/dist;
    index index.html;

    # 文件上传大小限制（默认20MB）
    client_max_body_size 50m;

    # Gzip 压缩（提升加载速度）
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript;
    gzip_min_length 1000;
    gzip_comp_level 6;

    # ==================== 企业微信/微信验证文件 ====================
    # 必须在 try_files 之前匹配，否则会被回退到 index.html 导致 404
    location ~* ^/(WW_verify_|MP_verify_).*\.txt$ {
        root /www/wwwroot/CRM/dist;
        default_type text/plain;
    }

    # ==================== H5 企微移动端应用 ====================
    # 企微内置H5应用（应用主页/桌面端独立主页）
    # 需先构建: cd h5 && npm run build
    location /h5/ {
        alias /www/wwwroot/CRM/h5/dist/;
        try_files $uri $uri/ /h5/index.html;
    }

    # ==================== 前端路由 ====================
    # Vue Router history 模式支持
    location / {
        try_files $uri $uri/ /index.html;
    }

    # 静态资源缓存（30天）
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # ==================== API 反向代理 ====================
    location /api/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # 超时配置
        proxy_connect_timeout 60s;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;

        # 关闭缓冲，支持流式响应（AI对话等）
        proxy_buffering off;
    }

    # ==================== WebSocket 代理 ====================
    # Socket.IO（实时消息推送）
    location /socket.io/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 86400s;
    }

    # 移动端 WebSocket
    location /ws/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 86400s;
    }

    # ==================== 文件上传/静态资源访问 ====================
    # 用户上传文件（^~ 确保优先于正则匹配，否则 .jpg/.png 会被静态资源缓存规则截获导致404）
    location ^~ /uploads/ {
        alias /www/wwwroot/CRM/backend/uploads/;
        expires 7d;
        add_header Cache-Control "public";
        add_header Access-Control-Allow-Origin *;
    }

    # 通话录音文件
    location ^~ /recordings/ {
        alias /www/wwwroot/CRM/backend/recordings/;
        expires 7d;
        add_header Cache-Control "public";
    }

    # ==================== 健康检查 ====================
    location /health {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        access_log off;
    }

    # ==================== 安全配置 ====================
    # 禁止访问隐藏文件（.env, .git 等）
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    # 禁止访问敏感文件
    location ~* \.(env|env\..*|sql|md|sh|bat|ps1|conf|log)$ {
        deny all;
    }

    # 禁止访问 node_modules
    location ~ /node_modules/ {
        deny all;
    }

    # 错误页面
    error_page 404 /index.html;
    error_page 500 502 503 504 /50x.html;
    location = /50x.html {
        root /usr/share/nginx/html;
    }
}

# ==================== HTTPS 配置（可选）====================
# 宝塔面板可以一键申请 Let's Encrypt 免费SSL证书
# 开启后会自动生成 HTTPS 配置，无需手动修改
#
# 手动配置参考:
# server {
#     listen 443 ssl http2;
#     server_name your-domain.com;
#
#     ssl_certificate /www/server/panel/vhost/cert/your-domain.com/fullchain.pem;
#     ssl_certificate_key /www/server/panel/vhost/cert/your-domain.com/privkey.pem;
#     ssl_protocols TLSv1.2 TLSv1.3;
#     ssl_ciphers HIGH:!aNULL:!MD5;
#
#     # ... 上面的 location 配置同样适用 ...
# }
#
# # HTTP 自动跳转 HTTPS
# server {
#     listen 80;
#     server_name your-domain.com;
#     return 301 https://$server_name$request_uri;
# }
